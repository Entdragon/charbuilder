# ── Security: block direct access to include/action files ─────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct web access to subdirectories
  RewriteRule ^includes/ - [F,L]
  RewriteRule ^actions/  - [F,L]

  # Clean URL: / loads index.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^$ index.php [L]

  # Route /api/ajax to ajax.php
  RewriteRule ^api/ajax/?$ ajax.php [L,QSA]
</IfModule>

# Hide PHP extension
<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>
