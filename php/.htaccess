# ── Security: block direct access to include/action files ─────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct web access to subdirectories
  RewriteRule ^includes/ - [F,L]
  RewriteRule ^actions/  - [F,L]

  # Clean URL: / loads index.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^$ index.php [L]

  # Route /uj and all /uj/* paths to uj.php
  RewriteRule ^uj(/.*)?$ uj.php [L,QSA]

  # Route /api/ajax to ajax.php
  RewriteRule ^api/ajax/?$ ajax.php [L,QSA]

  # Route GET /api/auth/me to ajax.php with cg_get_current_user action
  RewriteRule ^api/auth/me/?$ ajax.php?action=cg_get_current_user [L,QSA]
</IfModule>

# Hide PHP extension
<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

# Force browsers to revalidate JS/CSS so deploys take effect immediately
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
