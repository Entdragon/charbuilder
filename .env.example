# ── Database (WordPress MySQL) ─────────────────────────────────────────────────
# Host for your MySQL server (e.g. localhost, or a remote IP/hostname)
DB_HOST=localhost

# The WordPress database name
DB_NAME=your_wordpress_db

# MySQL user with read/write access to the database
DB_USER=your_db_user

# MySQL password for the above user
DB_PASS=your_db_password

# WordPress table prefix from wp-config.php (usually wp_)
DB_PREFIX=wp_

# ── Session ─────────────────────────────────────────────────────────────────────
# A long random string used to sign session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── CG Proxy (optional — used in production to verify requests) ────────────────
# Set these if you are using the proxy middleware; leave blank to skip proxy auth
CG_PROXY_URL=
CG_PROXY_SECRET=

# ── Test credentials (optional — for automated smoke tests only) ───────────────
CG_TEST_USER=
CG_TEST_PASS=
